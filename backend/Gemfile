source "https://rubygems.org"
git_source(:github) { |repo| "https://github.com/#{repo}.git" }

ruby "3.3.0"

# Rails 7.1, API-only. --skip-active-record: persistence is Mongoid, not AR.
gem "rails", "~> 7.1.0"
gem "puma", ">= 5.0"
gem "bootsnap", require: false

# MongoDB ODM behind the repository abstraction (see app/repositories).
gem "mongoid", "~> 9.0"

# Real SMS gateway (see app/gateways/twilio_sms_gateway.rb).
gem "twilio-ruby", "~> 7.0"

# CORS for the Angular dev server (config/initializers/cors.rb, CP12).
# Pinned (security-review-round1.md I3 / code-review-iteration-1.md NIT3):
# CORS is a security-relevant boundary, so don't let a floating version
# silently pick up breaking/behavior changes.
gem "rack-cors", "~> 2.0"

# Rate limiting/throttling (security-review-round1.md H1,
# config/initializers/rack_attack.rb). Protects POST /api/v1/messages from
# cost-abuse once real Twilio credentials are configured (SMS_PROVIDER=twilio) -
# each message send costs real money, and the only "auth" today is a
# self-issued signed cookie, so an unthrottled endpoint is an open wallet.
gem "rack-attack"

group :development, :test do
  gem "rspec-rails", "~> 6.1"
  gem "dotenv-rails"
end

group :test do
  gem "rack-test"
end
