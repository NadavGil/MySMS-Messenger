# Copy to backend/.env (dotenv-rails loads it in development/test) and/or
# export these in your shell / production environment. Never commit real
# values (tech-design.md §11, HLD §7.3 - secrets are never committed).

# MongoDB connection string. docker-compose.yml exposes Mongo on
# localhost:27017 for local dev; point this at Atlas or another host in
# other environments. Required (no default) in production.
MONGO_URI=mongodb://localhost:27017/mysms_development

# Repository implementation: mongo | in_memory
# Defaults to in_memory in test, mongo elsewhere.
MESSAGE_REPOSITORY=mongo

# SMS gateway implementation: fake | twilio
# Defaults to fake everywhere until Twilio credentials are supplied.
SMS_PROVIDER=fake

# Twilio credentials - NOT YET CONFIGURED. CityHive has not supplied live
# Twilio credentials; leave blank and SMS_PROVIDER=fake to run the full app
# end-to-end without real SMS delivery. Fill these in (and set
# SMS_PROVIDER=twilio) once the client provides them.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Comma-separated list of allowed CORS origins for the Angular dev server.
CORS_ORIGINS=http://localhost:4200
