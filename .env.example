# Copy to backend/.env (dotenv-rails loads it in development/test) and/or
# export these in your shell / production environment. Never commit real
# values (tech-design.md §11, HLD §7.3 - secrets are never committed).

# MongoDB connection string. docker-compose.yml exposes Mongo on
# localhost:27017 for local dev; point this at Atlas or another host in
# other environments. Required (no default) in production.
MONGO_URI=mongodb://localhost:27017/mysms_development

# Repository implementation: mongo | in_memory
# Defaults to in_memory in test, mongo elsewhere.
MESSAGE_REPOSITORY=mongo

# SMS gateway implementation: fake | twilio
# Defaults to fake everywhere until Twilio credentials are supplied.
SMS_PROVIDER=fake

# Twilio credentials - NOT YET CONFIGURED. CityHive has not supplied live
# Twilio credentials; leave blank and SMS_PROVIDER=fake to run the full app
# end-to-end without real SMS delivery. Fill these in (and set
# SMS_PROVIDER=twilio) once the client provides them.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Bonus 3 (tech-design.md §15.7/§15.9): the deployed backend's own public
# webhook URL, attached to outbound Twilio sends as status_callback so
# Twilio calls back with delivery-status updates. Must be an env var
# because the backend does not otherwise know its own public origin (same
# reason the frontend's apiBaseUrl is configured). Leave blank until real
# Twilio credentials exist - the webhook endpoint is disabled (503) whenever
# TWILIO_AUTH_TOKEN is blank, regardless of this value. Example once live:
# https://mysms-messenger-server.onrender.com/api/v1/webhooks/twilio/status
TWILIO_STATUS_CALLBACK_URL=

# Comma-separated list of allowed CORS origins for the Angular dev server.
CORS_ORIGINS=http://localhost:4200

# Cookie cross-origin mode (security-review-round1.md M3 / qa-report-round1.md
# M1): leave unset for same-origin/dev setups (msms_owner cookie stays
# SameSite=Lax). Set to "true" only for a genuine cross-origin production
# deployment (SPA and API on different registrable domains) - this switches
# the identity cookie to SameSite=None; Secure, which REQUIRES HTTPS
# (config.force_ssl is already on in production).
CROSS_ORIGIN_COOKIES=false

# Rails secret_key_base (security-review-round1.md M4) - required in
# production only (no config/master.key or credentials.yml.enc is committed
# to this repo by design). Generate with `bin/rails secret`.
SECRET_KEY_BASE=

# Emergency bypass for the rack-attack send-endpoint throttle
# (security-review-round1.md H1) - leave unset/false in normal operation.
RACK_ATTACK_DISABLED=false
